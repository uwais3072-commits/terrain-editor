local function logTerrain(pos, mat, size, shape)
    local k = string.format("%.1f_%.1f_%.1f", pos.X, pos.Y, pos.Z)
    terrainLog[k] = {position=pos, material=mat, size=size, shape=shape or "block"}
end

local function removeFromLog(pos)
    local k = string.format("%.1f_%.1f_%.1f", pos.X, pos.Y, pos.Z)
    terrainLog[k] = nil
end

local function addToHistory(action)
    table.insert(undoHistory, action)
    if #undoHistory > MAX_HISTORY then table.remove(undoHistory, 1) end
    redoHistory = {}
end

local function performUndo()
    if #undoHistory == 0 then return false end
    local a = table.remove(undoHistory)
    table.insert(redoHistory, a)
    if a.type == "place" then
        Terrain:FillBlock(CFrame.new(a.position), Vector3.new(a.size,a.size,a.size), Enum.Material.Air)
        removeFromLog(a.position)
    elseif a.type == "delete" then
        Terrain:FillBlock(CFrame.new(a.position), Vector3.new(a.size,a.size,a.size), a.material)
        logTerrain(a.position, a.material, a.size)
    end
    return true
end

local function performRedo()
    if #redoHistory == 0 then return false end
    local a = table.remove(redoHistory)
    table.insert(undoHistory, a)
    if a.type == "place" then
        Terrain:FillBlock(CFrame.new(a.position), Vector3.new(a.size,a.size,a.size), a.material)
        logTerrain(a.position, a.material, a.size)
    elseif a.type == "delete" then
        Terrain:FillBlock(CFrame.new(a.position), Vector3.new(a.size,a.size,a.size), Enum.Material.Air)
        removeFromLog(a.position)
    end
    return true
end

local function generateTerrainScript()
    local total = 0
    for _ in pairs(terrainLog) do total = total + 1 end
    if total == 0 then return "-- No terrain\nprint('No blocks')" end
    local dataLines = {}
    for _, block in pairs(terrainLog) do
        local p = block.position
        local mat = tostring(block.material):gsub("Enum.Material.", "")
        local sh = block.shape or "block"
        table.insert(dataLines, string.format("{%d,%d,%d,'%s',%d,'%s'}",
            math.floor(p.X), math.floor(p.Y), math.floor(p.Z), mat, block.size, sh))
    end
    local dataStr = table.concat(dataLines, ",")
    local loader = "-- Terrain by Uwais | " .. total .. " blocks\n"
        .. "local T=workspace.Terrain\n"
        .. "local D={" .. dataStr .. "}\n"
        .. "local M=Enum.Material\n"
        .. "for i,d in ipairs(D) do\n"
        .. "local p=Vector3.new(d[1],d[2],d[3])\n"
        .. "local m=M[d[4]]\nlocal s=d[5]\nlocal sh=d[6]\n"
        .. "if sh=='ball' then T:FillBall(p,s/2,m)\n"
        .. "elseif sh=='cylinder' then T:FillCylinder(CFrame.new(p),s/2,s,m)\n"
        .. "elseif sh=='wedge' then T:FillWedge(CFrame.new(p),Vector3.new(s,s,s),m)\n"
        .. "else T:FillBlock(CFrame.new(p),Vector3.new(s,s,s),m) end\n"
        .. "if i%20==0 then task.wait() end\n"
        .. "end\nprint('Loaded '..#D..' blocks')"
    if #loader >= 195000 then
        return "-- Terlalu banyak block! Hapus sebagian dulu."
    end
    return loader
end

