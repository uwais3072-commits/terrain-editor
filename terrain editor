-- RENDER STEPPED - brush indicator
-- ═══════════════════════════════════════════════════════════════

RunService.RenderStepped:Connect(function()
    if not terrainEnabled then
        brushIndicator.Transparency = 1
        selBox.Transparency = 1
        return
    end
    local ray = camera:ScreenPointToRay(mouse.X, mouse.Y)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {player.Character, brushIndicator}
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
    if result then
        local hp = result.Position
        local sp = Vector3.new(
            math.floor(hp.X/4)*4+2,
            math.floor(hp.Y/4)*4,
            math.floor(hp.Z/4)*4+2
        )
        brushIndicator.Position = sp
        brushIndicator.Size = Vector3.new(
            terrainWidth*4,
            math.max(terrainHeight*4*0.3, 0.5),
            terrainWidth*4
        )
        brushIndicator.Transparency = 0.8
        local col = deleteMode and C.maroon_bright or C.gold
        brushIndicator.Color = col
        selBox.Color3 = col
        selBox.SurfaceColor3 = col
        selBox.Transparency = 0.5
    else
        brushIndicator.Transparency = 1
        selBox.Transparency = 1
    end
end)

-- ═══════════════════════════════════════════════════════════════
-- HEARTBEAT - terrain placement
-- ═══════════════════════════════════════════════════════════════

RunService.Heartbeat:Connect(function()
    if not terrainEnabled or not isPlacing or brushIndicator.Transparency >= 1 then return end
    local now = tick()
    if now - lastPlacementTime < PLACEMENT_COOLDOWN then return end
    lastPlacementTime = now

    local pos = brushIndicator.Position
    local width  = terrainWidth  * 4
    local height = terrainHeight * 4
    local size   = brushSize * 4

    -- FLATTEN
    if flattenActive and flattenYSet then
        local flatPos = Vector3.new(pos.X, flattenY, pos.Z)
        local clearTop = Region3.new(
            flatPos + Vector3.new(-width/2, 0, -width/2),
            flatPos + Vector3.new(width/2, height+40, width/2)
        )
        clearTop = clearTop:ExpandToGrid(4)
        Terrain:FillRegion(clearTop, 4, Enum.Material.Air)
        Terrain:FillBlock(CFrame.new(flatPos - Vector3.new(0,2,0)), Vector3.new(width,4,width), selectedMaterial)
        return
    end

    -- SMOOTH
    if smoothActive then
        local offsets = {Vector3.new(4,0,0),Vector3.new(-4,0,0),Vector3.new(0,0,4),Vector3.new(0,0,-4)}
        for iter = 1, smoothStrength do
            for _, offset in ipairs(offsets) do
                local sPos = pos + offset * iter
                Terrain:FillBall(sPos, 2*smoothStrength, Enum.Material.Air)
                task.wait()
                Terrain:FillBall(sPos, 1.5*smoothStrength, selectedMaterial)
            end
        end
        return
    end

    -- DELETE
    if deleteMode then
        local region = Region3.new(
            pos - Vector3.new(width/2,height/2,width/2),
            pos + Vector3.new(width/2,height/2,width/2)
        )
        region = region:ExpandToGrid(4)
        addToHistory({type="delete", position=pos, material=selectedMaterial, size=size})
        Terrain:FillRegion(region, 4, Enum.Material.Air)
        Terrain:FillBlock(CFrame.new(pos), Vector3.new(width,height,width), Enum.Material.Air)
        removeFromLog(pos)
    else
        -- PLACE
        addToHistory({type="place", position=pos, material=selectedMaterial, size=size})
        if selectedTerrainShape == "ball" then
            Terrain:FillBall(pos, math.max(width,height)/2, selectedMaterial)
        elseif selectedTerrainShape == "cylinder" then
            Terrain:FillCylinder(CFrame.new(pos), width/2, height, selectedMaterial)
        elseif selectedTerrainShape == "wedge" then
            Terrain:FillWedge(CFrame.new(pos), Vector3.new(width,height,width), selectedMaterial)
        else
            Terrain:FillBlock(CFrame.new(pos), Vector3.new(width,height,width), selectedMaterial)
        end
        logTerrain(pos, selectedMaterial, size, selectedTerrainShape)
    end
end)

